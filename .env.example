# ============================================================
# fazle-ai-health-api — Environment Variables Template
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env — it is gitignored
# ============================================================

# Application Settings
APP_ENV=development
APP_VERSION=1.0.0

# Gemini Free Tier Config
# Get your key: https://aistudio.google.com/apikey
# Key format: AIza...
# Auth: x-goog-api-key header (NOT Authorization: Bearer like OpenAI)
GEMINI_API_KEY=AIza-your-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MODEL=gemini-3.5-flash
LLM_TIMEOUT_SECONDS=10